{
  "name": "",
  "version": "1.6.1",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix vite:build && npm run build:worker",
    "build:worker": "node scripts/build-worker.mjs",
    "dev:web": "remix vite:dev --host",
    "dev:worker": "tsx watch scripts/worker.ts",
    "dev": "concurrently -c \"blue,green\" -n \"web,worker\" \"npm run dev:web\" \"npm run dev:worker\"",
    "predev": "drizzle-kit push",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "remix-serve build/server/index.js",
    "start:worker": "node build/worker.js",
    "prestart": "drizzle-kit migrate",
    "typecheck": "tsc && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run --exclude \"**/*.integration.test.ts\"",
    "test:watch": "vitest --exclude \"**/*.integration.test.ts\"",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage --exclude \"**/*.integration.test.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "sync:users": "tsx scripts/sync-auth-users.ts",
    "init:feature-flags": "tsx scripts/init-feature-flags.ts",
    "seed:email-config": "tsx scripts/seed-email-config.ts",
    "worker": "tsx scripts/worker.ts",
    "worker:dev": "tsx watch scripts/worker.ts",
    "prepare": "node scripts/prepare-husky.mjs"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --cache --cache-location ./node_modules/.cache/eslint --fix"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.856.0",
    "@aws-sdk/lib-storage": "^3.978.0",
    "@aws-sdk/s3-request-presigner": "^3.856.0",
    "@react-email/render": "^2.0.4",
    "@react-three/drei": "^9.117.3",
    "@react-three/fiber": "^8.17.10",
    "@remix-run/node": "^2.17.5",
    "@remix-run/react": "^2.17.5",
    "@remix-run/serve": "^2.17.5",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.50.3",
    "@types/archiver": "^6.0.3",
    "archiver": "^7.0.1",
    "date-holidays": "^3.30.2",
    "dotenv": "^17.2.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "isbot": "^4.1.0",
    "lightningcss": "^1.30.1",
    "lucide-react": "^0.552.0",
    "marked": "^17.0.5",
    "match-sorter": "^6.3.1",
    "mupdf": "^1.26.4",
    "pg-boss": "^12.14.0",
    "postgres": "^3.4.7",
    "puppeteer": "^24.23.0",
    "react": "^18.2.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18.2.0",
    "sanitize-html": "^2.17.4",
    "stripe": "^20.4.1",
    "three": "^0.179.1",
    "three-stdlib": "^2.36.0",
    "tiny-invariant": "^1.3.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@babel/traverse": "^7.28.0",
    "@remix-run/dev": "^2.17.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "@types/sanitize-html": "^2.16.1",
    "@types/three": "^0.179.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "eslint": "^8.47.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "happy-dom": "^20.10.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.6",
    "remix-flat-routes": "^0.8.5",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.1.6",
    "vite": "^6.4.3",
    "vite-tsconfig-paths": "^4.3.1",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "rollup": "npm:@rollup/wasm-node",
    "glob": "^10.5.0",
    "@remix-run/router": "^1.23.3",
    "esbuild": "^0.28.1",
    "turbo-stream": "3.0.0",
    "ws": "^8.21.0",
    "express": {
      "path-to-regexp": "0.1.13"
    },
    "picomatch": "2.3.2",
    "vite": {
      ".": "^6.4.3",
      "picomatch": "4.0.4"
    },
    "tinyglobby": {
      "picomatch": "4.0.4"
    },
    "fdir": {
      "picomatch": "4.0.4"
    },
    "qs": "^6.14.1",
    "fast-xml-builder": "^1.1.7",
    "fast-xml-parser": "^5.7.0",
    "estree-util-value-to-estree": "^3.3.3",
    "undici": "^6.27.0",
    "flatted": ">=3.4.2",
    "axios": "^1.13.5",
    "minimatch": "^10.0.0",
    "tar": ">=7.6.0",
    "cacache": ">=19.0.0",
    "basic-ftp": ">=5.3.1"
  }
}
